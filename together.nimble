version     = "0.3.0"
author      = "Wal33D"
description = "Together - A narrative puzzle-platformer about colored rectangles discovering consciousness, friendship, and what it means to belong. Rebuilt in Nim."
license     = "MIT"

srcDir = "src"

bin = @["together"]

requires "nim >= 2.0.0"
requires "boxy >= 0.7.0"
requires "windy >= 0.4.4"
requires "silky >= 0.0.1"
requires "pixie >= 5.1.0"
requires "jsony >= 1.1.0"
